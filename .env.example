# Application Password
NEXT_PUBLIC_PASSWORD=your_password_here

# Geocoding API Key
# Get your API key from: https://opencagedata.com/api (or your chosen geocoding service)
NEXT_PUBLIC_GEOCODING_API_KEY=your_geocoding_api_key_here

# Google Cloud API Key (required for AddressSearch autocomplete)
# Get your API key from: https://console.cloud.google.com/
# Required APIs: Maps JavaScript API, Places API
NEXT_PUBLIC_GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here

# Parent origin for iframe postMessage security
# Uncomment and set to the parent website's origin (e.g., https://parentwebsite.com)
# If not set, will auto-detect from document.referrer
# NEXT_PUBLIC_PARENT_ORIGIN=https://parentwebsite.com
